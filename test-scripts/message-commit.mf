PUBLISH_MODS=(mosta-api-keys mosta-audit mosta-auth mosta-cloud-config mosta-cloud-middleware mosta-face
   mosta-init mosta-media mosta-menu mosta-ornetadmin mosta-payment mosta-pm2 mosta-project-life mosta-pwa-scan
   mosta-scan mosta-secu mosta-settings mosta-setup mosta-socle mosta-subscriptions mosta-subscriptions-plan
   mosta-themes mosta-ticketing mosta-ui mosta-weather)

   SUCCESS=()
   FAILED=()

   for m in "${PUBLISH_MODS[@]}"; do
     cd "/home/hmd/dev/MostaGare-Install/mostajs/$m"

     name=$(node -p "require('./package.json').name")

     # Bump version
     current=$(node -p "require('./package.json').version")
     new_version=$(node -e "
       const v = require('./package.json').version.split('.');
       v[2] = String(parseInt(v[2]) + 1);
       console.log(v.join('.'));
     ")
     node -e "
       const fs = require('fs');
       const pkg = JSON.parse(fs.readFileSync('./package.json', 'utf8'));
       pkg.version = '$new_version';
       fs.writeFileSync('./package.json', JSON.stringify(pkg, null, 2) + '\n');
     "

     # Git commit + push (if git repo)
     if [ -d ".git" ]; then
       branch=$(git rev-parse --abbrev-ref HEAD)
       git add package.json 2>/dev/null
       git commit -m "chore: bump to $new_version (license change)" 2>&1 > /dev/null
       git push origin "$branch" 2>&1 > /dev/null
     fi

     # npm publish
     if npm publish --access public 2>&1 | grep -q "^+ $name@"; then
       SUCCESS+=("$name@$new_version")
       printf "%-35s OK %s -> %s\n" "$name" "$current" "$new_version"
     else
       FAILED+=("$name")
       printf "%-35s FAIL (see logs)\n" "$name"
     fi
   done

   echo ""
   echo "=== SUMMARY ==="
   echo "SUCCESS: ${#SUCCESS[@]}"
   echo "FAILED: ${#FAILED[@]}"
   printf '  - %s\n' "${FAILED[@]}"
